<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="arm">

  
  <xacro:include filename="$(find arm_description)/urdf/materials.xacro"/>
  <xacro:include filename="$(find arm_description)/urdf/arm_ros2_control.xacro"/>
  <xacro:include filename="$(find arm_description)/urdf/arm_gazebo.xacro"/>

  

  
  <xacro:macro name="cylinder_inertia" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${(m/12.0)*(3*r*r + l*l)}"
        ixy="0.0"  ixz="0.0"
        iyy="${(m/12.0)*(3*r*r + l*l)}"
        iyz="0.0"
        izz="${(m/2.0)*(r*r)}"/>
    </inertial>
  </xacro:macro>

  
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${(m/12.0)*(y*y + z*z)}"
        ixy="0.0" ixz="0.0"
        iyy="${(m/12.0)*(x*x + z*z)}"
        iyz="0.0"
        izz="${(m/12.0)*(x*x + y*y)}"/>
    </inertial>
  </xacro:macro>

  
  <link name="world"/>

  <!-- ============================================================ -->
  <!-- BASE LINK: cylinder r=0.12, l=0.10, m=5.0 kg                -->
  <!-- Ixx=Iyy = 5/12*(3*0.12^2+0.10^2) = 0.02567                 -->
  <!-- Izz    = 5/2*(0.12^2) = 0.036                               -->
  <!-- ============================================================ -->
  <link name="base_link">
    <!-- Active Base visual -->
    <visual>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.12" length="0.25"/>
      </geometry>
      <material name="dark_charcoal"/>
    </visual>
    
    <!-- Active Base collision -->
    <collision>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.12" length="0.25"/>
      </geometry>
    </collision>
    
    <!-- Active Base Inertial Properties -->
    <inertial>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.044041" ixy="0.0" ixz="0.0"
               iyy="0.044041" iyz="0.0" izz="0.036000"/>
    </inertial>
  </link>

  
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================ -->
  <!-- LINK 1: cylinder r=0.05, l=0.15, m=2.0 kg                   -->
  <!-- Ixx=Iyy = 2/12*(3*0.05^2+0.15^2) = 0.005                   -->
  <!-- Izz    = 2/2*(0.05^2) = 0.0025                              -->
  <!-- ============================================================ -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.20"/>
      </geometry>
      <material name="aluminium"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.20"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <mass value="2.5"/>
      <inertia ixx="0.010000" ixy="0.0" ixz="0.0"
               iyy="0.010000" iyz="0.0" izz="0.010000"/>
    </inertial>
  </link>

  
  <!-- Joint 1: base rotation (yaw) -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159"
           velocity="0.5" effort="1000.0"/>
    <dynamics damping="15.0" friction="5.0"/>
  </joint>

  <!-- ============================================================ -->
  <!-- LINK 2: box 0.06 x 0.06 x 0.22, m=1.5 kg (vertical shoulder)-->
  <!-- ============================================================ -->
  <link name="link2">
    <visual>
      <origin xyz="0 0 0.11" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.22"/>
      </geometry>
      <material name="aluminium"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.11" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.22"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.11" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.010000" ixy="0.0" ixz="0.0"
               iyy="0.010000" iyz="0.0" izz="0.010000"/>
    </inertial>
  </link>

  
  <!-- Joint 2: shoulder pitch -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159"
           velocity="0.5" effort="1000.0"/>
    <dynamics damping="15.0" friction="5.0"/>
  </joint>

  <!-- ============================================================ -->
  <!-- LINK 3: box 0.40 x 0.05 x 0.05, m=1.2 kg (forearm)         -->
  <!-- Ixx = 1.2/12*(0.05^2+0.05^2) = 0.0005                      -->
  <!-- Iyy = 1.2/12*(0.40^2+0.05^2) = 0.01625                     -->
  <!-- Izz = 1.2/12*(0.40^2+0.05^2) = 0.01625                     -->
  <!-- ============================================================ -->
  <link name="link3">
    <visual>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.05 0.05"/>
      </geometry>
      <material name="aluminium"/>
    </visual>
    <collision>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.05 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.125 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.015000" ixy="0.0" ixz="0.0"
               iyy="0.015000" iyz="0.0" izz="0.015000"/>
    </inertial>
  </link>

  
  <!-- Joint 3: elbow pitch -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.22" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5307" upper="2.5307"
           velocity="0.5" effort="1000.0"/>
    <dynamics damping="10.0" friction="3.0"/>
  </joint>

  <!-- ============================================================ -->
  <!-- LINK 4: cylinder r=0.035, l=0.08, m=0.8 kg (wrist roll)     -->
  <!-- Ixx=Iyy = 0.8/12*(3*0.035^2+0.08^2) = 0.000672             -->
  <!-- Izz    = 0.8/2*(0.035^2) = 0.00049                          -->
  <!-- ============================================================ -->
  <link name="link4">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.08"/>
      </geometry>
      <material name="joint_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.08"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.010000" ixy="0.0" ixz="0.0"
               iyy="0.010000" iyz="0.0" izz="0.010000"/>
    </inertial>
  </link>

  
  <!-- Joint 4: wrist roll -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14159" upper="3.14159"
           velocity="0.5" effort="1000.0"/>
   <dynamics damping="10.0" friction="3.0"/>
  </joint>

  <!-- ============================================================ -->
  <!-- LINK 5: cylinder r=0.030, l=0.08, m=0.5 kg (wrist pitch)    -->
  <!-- Ixx=Iyy = 0.5/12*(3*0.030^2+0.08^2) = 0.000379             -->
  <!-- Izz    = 0.5/2*(0.030^2) = 0.000225                         -->
  <!-- ============================================================ -->
  <link name="link5">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.030" length="0.08"/>
      </geometry>
      <material name="joint_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.030" length="0.08"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <mass value="0.7"/>
      <inertia ixx="0.010000" ixy="0.0" ixz="0.0"
               iyy="0.010000" iyz="0.0" izz="0.010000"/>
    </inertial>
  </link>

  
  <!-- Joint 5: wrist pitch -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159"
           velocity="0.5" effort="1000.0"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <!-- ============================================================ -->
  <!-- LINK 6: cylinder r=0.025, l=0.06, m=0.3 kg (wrist yaw)      -->
  <!-- Ixx=Iyy = 0.3/12*(3*0.025^2+0.06^2) = 0.000137             -->
  <!-- Izz    = 0.3/2*(0.025^2) = 0.00009375                       -->
  <!-- ============================================================ -->
  <link name="link6">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.06"/>
      </geometry>
      <material name="joint_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.010000" ixy="0.0" ixz="0.0"
               iyy="0.010000" iyz="0.0" izz="0.010000"/>
    </inertial>
  </link>

  
  <!-- Joint 6: wrist yaw — velocity capped to 0.5, effort reduced -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159"
           velocity="0.5" effort="1000.0"/>
   <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <!-- ============================================================ -->
  <!-- GRIPPER BASE: box 0.05 x 0.08 x 0.04, m=0.3 kg             -->
  <!-- Ixx = 0.3/12*(0.08^2+0.04^2) = 0.0002                      -->
  <!-- Iyy = 0.3/12*(0.05^2+0.04^2) = 0.000103                    -->
  <!-- Izz = 0.3/12*(0.05^2+0.08^2) = 0.000223                    -->
  <!-- ============================================================ -->
  <link name="gripper_base_link">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.08 0.04"/>
      </geometry>
      <material name="gripper_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.08 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.010000" ixy="0.0" ixz="0.0"
               iyy="0.010000" iyz="0.0" izz="0.010000"/>
    </inertial>
  </link>

  
  <joint name="joint6_to_gripper" type="fixed">
    <parent link="link6"/>
    <child link="gripper_base_link"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================ -->
  <!-- LEFT FINGER: box 0.04 x 0.04 x 0.10, m=0.15 kg              -->
  <!-- Wide flat contact pad for maximum grip surface area           -->
  <!-- ============================================================ -->
  <link name="left_finger_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.02 0.10"/>
      </geometry>
      <material name="gripper_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.02 0.10"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.010000" ixy="0.0" ixz="0.0"
               iyy="0.010000" iyz="0.0" izz="0.010000"/>
    </inertial>
  </link>

  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="left_finger_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.05" velocity="0.05" effort="20.0"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>

  <!-- ============================================================ -->
  <!-- RIGHT FINGER: box 0.04 x 0.04 x 0.10, m=0.15 kg             -->
  <!-- Wide flat contact pad for maximum grip surface area           -->
  <!-- ============================================================ -->
  <link name="right_finger_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.02 0.10"/>
      </geometry>
      <material name="gripper_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.02 0.10"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.010000" ixy="0.0" ixz="0.0"
               iyy="0.010000" iyz="0.0" izz="0.010000"/>
    </inertial>
  </link>

  <joint name="right_finger_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="right_finger_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.05" velocity="0.05" effort="20.0"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>

  <link name="tool0"/>

  <joint name="gripper_to_tool0" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="tool0"/>
    <!-- z=0.09: grasp center between the 10cm long fingers -->
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
  </joint>

  <!-- Debug Marker: Open Width (0.07m gap) -->
  <link name="debug_open_marker">
    <visual>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.07 0.01"/>
      </geometry>
      <material name="debug_green">
        <color rgba="0 1 0 0.3"/>
      </material>
    </visual>
  </link>
  <joint name="debug_open_joint" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="debug_open_marker"/>
  </joint>

  <!-- Debug Marker: Closed Width (0.044m gap) -->
  <link name="debug_closed_marker">
    <visual>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.044 0.01"/>
      </geometry>
      <material name="debug_red">
        <color rgba="1 0 0 0.5"/>
      </material>
    </visual>
  </link>
  <joint name="debug_closed_joint" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="debug_closed_marker"/>
  </joint>



</robot>
