<!-- ============================================================
     arm_description/urdf/arm.urdf.xacro
     Complete 6-DOF robotic arm with parallel gripper.

     KINEMATIC CHAIN:
       world -> base_link -> link1 -> link2 -> link3
             -> link4 -> link5 -> link6
             -> gripper_base_link
             -> left_finger_link / right_finger_link
             -> camera_link -> camera_optical_frame

     JOINT TYPES:
       joint1..joint6   : revolute
       left/right_finger: prismatic
       fixed joints     : world_to_base, gripper_base, camera

     DH PARAMETERS (Modified DH):
       J1: a=0,    d=0.15, alpha=pi/2,  theta=0
       J2: a=0.30, d=0,    alpha=0,     theta=-pi/2
       J3: a=0.25, d=0,    alpha=0,     theta=0
       J4: a=0,    d=0.08, alpha=pi/2,  theta=0
       J5: a=0,    d=0.08, alpha=-pi/2, theta=0
       J6: a=0,    d=0.06, alpha=0,     theta=0
     ============================================================ -->
<robot name="arm">
  <!-- Dark Charcoal — used for the robot base -->
  <material name="dark_charcoal">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <!-- Aluminium Silver — used for arm links -->
  <material name="aluminium">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>
  <!-- Joint Blue — used for joint cylinders -->
  <material name="joint_blue">
    <color rgba="0.1 0.4 0.8 1.0"/>
  </material>
  <!-- Gripper Orange — used for gripper fingers -->
  <material name="gripper_orange">
    <color rgba="0.9 0.5 0.1 1.0"/>
  </material>
  <!-- Red — used for end effector tip indicator -->
  <material name="red">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>
  <!-- White — general purpose -->
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <!-- Yellow — warning indicator -->
  <material name="yellow">
    <color rgba="0.9 0.9 0.0 1.0"/>
  </material>
  <ros2_control name="ArmSystem" type="system">
    <!-- ── Hardware Plugin ────────────────────────────────────────────── -->
    <!-- In Gazebo, this is overridden by gazebo_ros2_control plugin.     -->
    <!-- For real hardware, replace with your hardware interface plugin.  -->
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <!-- ── Joint 1: Base Rotation (Z-axis) ───────────────────────────── -->
    <joint name="joint1">
      <command_interface name="position">
        <param name="min">-3.14159</param>
        <param name="max">3.14159</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- ── Joint 2: Shoulder Pitch ────────────────────────────────────── -->
    <joint name="joint2">
      <command_interface name="position">
        <param name="min">-1.5708</param>
        <param name="max">1.5708</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- ── Joint 3: Elbow Pitch ───────────────────────────────────────── -->
    <joint name="joint3">
      <command_interface name="position">
        <param name="min">-2.5307</param>
        <param name="max">2.5307</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- ── Joint 4: Wrist 1 (Roll) ────────────────────────────────────── -->
    <joint name="joint4">
      <command_interface name="position">
        <param name="min">-3.14159</param>
        <param name="max">3.14159</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- ── Joint 5: Wrist 2 (Pitch) ──────────────────────────────────── -->
    <joint name="joint5">
      <command_interface name="position">
        <param name="min">-1.5708</param>
        <param name="max">1.5708</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- ── Joint 6: Wrist 3 (Tool Roll) ──────────────────────────────── -->
    <joint name="joint6">
      <command_interface name="position">
        <param name="min">-3.14159</param>
        <param name="max">3.14159</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- ── Left Finger Joint (Gripper) ───────────────────────────────── -->
    <!-- Prismatic joint: 0.0 = closed, 0.04 = fully open -->
    <joint name="left_finger_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.04</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- ── Right Finger Joint (Gripper) ──────────────────────────────── -->
    <!-- Mirrored prismatic joint, also commanded independently -->
    <joint name="right_finger_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.04</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>
  <!-- ── Gazebo physics properties for each link ────────────────────────── -->
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.9</mu1>
    <mu2>0.9</mu2>
    <selfCollide>false</selfCollide>
    <gravity>true</gravity>
  </gazebo>
  <gazebo reference="link1">
    <material>Gazebo/Grey</material>
    <mu1>0.5</mu1>
    <mu2>0.5</mu2>
    <selfCollide>false</selfCollide>
  </gazebo>
  <gazebo reference="link2">
    <material>Gazebo/Grey</material>
    <mu1>0.5</mu1>
    <mu2>0.5</mu2>
    <selfCollide>false</selfCollide>
  </gazebo>
  <gazebo reference="link3">
