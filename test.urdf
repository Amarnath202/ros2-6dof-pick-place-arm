      <inertia ixx="0.0000148" ixy="0.0" ixz="0.0" iyy="0.0000019" iyz="0.0" izz="0.0000148"/>
    </inertial>
  </link>
  <!-- Left finger joint: prismatic along Y-axis -->
  <!-- 0 = fully closed, 0.04 = fully open (40mm travel) -->
  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="left_finger_link"/>
    <origin rpy="0 0 0" xyz="0 0.01 0.04"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" lower="0.0" upper="0.04" velocity="0.5"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <!-- ═══════════════════════════════════════════════════════════════════
       RIGHT FINGER LINK
       Mirrored prismatic: slides along negative Y-axis
       Dimensions: box 0.015 × 0.07 × 0.015 m
       Mass: 0.05 kg
       ═══════════════════════════════════════════════════════════════════ -->
  <link name="right_finger_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 -0.035 0"/>
      <geometry>
        <box size="0.015 0.07 0.02"/>
      </geometry>
      <material name="gripper_orange"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 -0.035 0"/>
      <geometry>
        <box size="0.015 0.07 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 -0.035 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.0000148" ixy="0.0" ixz="0.0" iyy="0.0000019" iyz="0.0" izz="0.0000148"/>
    </inertial>
  </link>
  <!-- Right finger joint: prismatic along negative Y-axis (mirror of left) -->
  <joint name="right_finger_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="right_finger_link"/>
    <origin rpy="0 0 0" xyz="0 -0.01 0.04"/>
    <axis xyz="0 -1 0"/>
    <limit effort="10.0" lower="0.0" upper="0.04" velocity="0.5"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <!-- ═══════════════════════════════════════════════════════════════════
       TOOL CENTER POINT (TCP) — Virtual end-effector reference frame
       Used by MoveIt2 as the planning reference frame
       ═══════════════════════════════════════════════════════════════════ -->
  <link name="tool0"/>
  <joint name="gripper_to_tool0" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="tool0"/>
    <!-- TCP is between the fingers, 0.08 m below gripper base -->
    <origin rpy="0 0 0" xyz="0 0 0.08"/>
  </joint>
  <!-- ═══════════════════════════════════════════════════════════════════
       CAMERA LINK — Wrist-mounted camera
       Mounted on link6, facing downward (-Z direction)
       ═══════════════════════════════════════════════════════════════════ -->
  <link name="camera_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.03"/>
      </geometry>
      <material name="dark_charcoal"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0000083" ixy="0.0" ixz="0.0" iyy="0.0000083" iyz="0.0" izz="0.0000083"/>
    </inertial>
  </link>
  <!-- Camera mounted on link6, offset sideways to avoid gripper occlusion -->
  <joint name="link6_to_camera" type="fixed">
    <parent link="link6"/>
    <child link="camera_link"/>
    <!-- Offset: 0.05 m forward, pointing downward (rotated -90° on Y-axis) -->
    <origin rpy="0 1.5708 0" xyz="0.05 0 0.02"/>
  </joint>
  <!-- Camera optical frame: ROS convention (Z forward, X right, Y down) -->
  <link name="camera_optical_frame"/>
  <joint name="camera_to_optical" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <!-- Transform from camera_link (X-forward convention) to -->
    <!-- optical frame (Z-forward, X-right, Y-down convention) -->
    <origin rpy="-1.5708 0 -1.5708" xyz="0 0 0"/>
  </joint>
</robot>
