  <!-- Joint 6: Tool roll (Z-axis) -->
  <!-- Origin: top of link5 -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin rpy="0 0 0" xyz="0 0 0.08"/>
    <axis xyz="0 0 1"/>
    <limit effort="20.0" lower="-3.14159" upper="3.14159" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.02"/>
  </joint>
  <!-- ═══════════════════════════════════════════════════════════════════
       GRIPPER BASE LINK
       Connects the wrist to the gripper mechanism
       Dimensions: box 0.05 × 0.06 × 0.04 m
       Mass: 0.15 kg
       ═══════════════════════════════════════════════════════════════════ -->
  <link name="gripper_base_link">
