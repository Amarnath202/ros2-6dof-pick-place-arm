    <limit effort="30.0" lower="-1.5708" upper="1.5708" velocity="3.0"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>
  <!-- ═══════════════════════════════════════════════════════════════════
       LINK 6 — Wrist 3 / Tool Flange (yaw)
       Dimensions: cylinder h=0.06 m, r=0.025 m
       Mass: 0.2 kg
       Joint6 is revolute around Z-axis (tool roll)
       ═══════════════════════════════════════════════════════════════════ -->
  <link name="link6">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.03"/>
