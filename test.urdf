    <mu2>0.5</mu2>
    <selfCollide>false</selfCollide>
  </gazebo>
  <gazebo reference="gripper_base_link">
    <material>Gazebo/Orange</material>
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <selfCollide>false</selfCollide>
  </gazebo>
  <gazebo reference="left_finger_link">
    <material>Gazebo/Orange</material>
    <mu1>1.2</mu1>
    <mu2>1.2</mu2>
    <selfCollide>false</selfCollide>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <gazebo reference="right_finger_link">
    <material>Gazebo/Orange</material>
    <mu1>1.2</mu1>
    <mu2>1.2</mu2>
    <selfCollide>false</selfCollide>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <!-- ── Wrist-mounted Camera ──────────────────────────────────────────── -->
  <!-- The camera is mounted on link6 (end-effector wrist) facing downward -->
  <gazebo reference="camera_link">
    <material>Gazebo/Black</material>
    <selfCollide>false</selfCollide>
    <!-- RGB camera plugin -->
    <sensor name="wrist_camera" type="camera">
      <update_rate>30.0</update_rate>
      <visualize>true</visualize>
      <camera name="wrist_camera">
        <horizontal_fov>1.047</horizontal_fov>
        <!-- 60 degrees FOV -->
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>5.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <plugin filename="libgazebo_ros_camera.so" name="camera_controller">
        <alwaysOn>true</alwaysOn>
        <updateRate>30.0</updateRate>
        <cameraName>wrist_camera</cameraName>
        <imageTopicName>/wrist_camera/image_raw</imageTopicName>
        <cameraInfoTopicName>/wrist_camera/camera_info</cameraInfoTopicName>
        <frameName>camera_optical_frame</frameName>
        <hackBaseline>0.0</hackBaseline>
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <!-- Path to the controllers YAML configuration (set by launch file) -->
      <parameters></parameters>
      <robotSimType>gazebo_ros2_control/GazeboSystem</robotSimType>
    </plugin>
  </gazebo>
  <!-- ── Reusable inertia macros ──────────────────────────────────────── -->
  <!-- ═══════════════════════════════════════════════════════════════════
       WORLD LINK — virtual fixed reference frame
       ═══════════════════════════════════════════════════════════════════ -->
  <link name="world"/>
  <!-- ═══════════════════════════════════════════════════════════════════
       BASE LINK — robot body fixed to the ground
       Dimensions: cylinder h=0.10 m, r=0.12 m
       Mass: 2.0 kg
       ═══════════════════════════════════════════════════════════════════ -->
  <link name="base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.05"/>
      <geometry>
        <cylinder length="0.10" radius="0.12"/>
      </geometry>
      <material name="dark_charcoal"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.05"/>
      <geometry>
        <cylinder length="0.10" radius="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.05"/>
      <mass value="2.0"/>
      <inertia ixx="0.0208" ixy="0.0" ixz="0.0" iyy="0.0208" iyz="0.0" izz="0.0360"/>
    </inertial>
  </link>
  <!-- Fixed joint: world -> base_link -->
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <!-- ═══════════════════════════════════════════════════════════════════
       LINK 1 — Shoulder / Base rotation output
       Dimensions: cylinder h=0.15 m, r=0.05 m
       Mass: 1.5 kg
       Joint1 is revolute around Z-axis (yaw)
       ═══════════════════════════════════════════════════════════════════ -->
  <link name="link1">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.075"/>
      <geometry>
        <cylinder length="0.15" radius="0.05"/>
      </geometry>
      <material name="aluminium"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.075"/>
      <geometry>
        <cylinder length="0.15" radius="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.075"/>
      <mass value="1.5"/>
      <inertia ixx="0.0103" ixy="0.0" ixz="0.0" iyy="0.0103" iyz="0.0" izz="0.0019"/>
    </inertial>
  </link>
  <!-- Joint 1: Base rotation around Z-axis (yaw) -->
  <!-- Origin: top of base_link (z=0.10) -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin rpy="0 0 0" xyz="0 0 0.10"/>
    <axis xyz="0 0 1"/>
    <limit effort="50.0" lower="-3.14159" upper="3.14159" velocity="2.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <!-- ═══════════════════════════════════════════════════════════════════
       LINK 2 — Upper arm (between shoulder and elbow)
       Dimensions: box 0.30 × 0.06 × 0.06 m
       Mass: 1.2 kg
       Joint2 is revolute around Y-axis (shoulder pitch)
       ═══════════════════════════════════════════════════════════════════ -->
  <link name="link2">
    <visual>
      <origin rpy="0 0 0" xyz="0.15 0 0"/>
      <geometry>
        <box size="0.30 0.06 0.06"/>
      </geometry>
      <material name="aluminium"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.15 0 0"/>
      <geometry>
        <box size="0.30 0.06 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.15 0 0"/>
      <mass value="1.2"/>
      <inertia ixx="0.000720" ixy="0.0" ixz="0.0" iyy="0.009036" iyz="0.0" izz="0.009036"/>
    </inertial>
  </link>
  <!-- Joint 2: Shoulder pitch (Y-axis) -->
  <!-- Origin: top of link1 -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin rpy="0 0 0" xyz="0 0 0.15"/>
    <axis xyz="0 1 0"/>
    <limit effort="80.0" lower="-1.5708" upper="1.5708" velocity="2.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>
  <!-- ═══════════════════════════════════════════════════════════════════
       LINK 3 — Forearm (between elbow and wrist)
       Dimensions: box 0.25 × 0.05 × 0.05 m
       Mass: 0.9 kg
       Joint3 is revolute around Y-axis (elbow pitch)
       ═══════════════════════════════════════════════════════════════════ -->
  <link name="link3">
    <visual>
      <origin rpy="0 0 0" xyz="0.125 0 0"/>
