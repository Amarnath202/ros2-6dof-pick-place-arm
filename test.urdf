    </inertial>
  </link>
  <!-- Joint 3: Elbow pitch (Y-axis) -->
  <!-- Origin: end of link2 (x=0.30 from link2 origin) -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin rpy="0 0 0" xyz="0.30 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="60.0" lower="-2.5307" upper="2.5307" velocity="2.0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>
  <!-- ═══════════════════════════════════════════════════════════════════
       LINK 4 — Wrist 1 (roll)
       Dimensions: cylinder h=0.08 m, r=0.035 m
       Mass: 0.4 kg
       Joint4 is revolute around X-axis (roll)
       ═══════════════════════════════════════════════════════════════════ -->
  <link name="link4">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.04"/>
      <geometry>
        <cylinder length="0.08" radius="0.035"/>
      </geometry>
      <material name="joint_blue"/>
    </visual>
    <collision>
