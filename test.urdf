      <geometry>
        <cylinder length="0.08" radius="0.035"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.04"/>
      <mass value="0.4"/>
      <inertia ixx="0.000258" ixy="0.0" ixz="0.0" iyy="0.000258" iyz="0.0" izz="0.000245"/>
    </inertial>
  </link>
  <!-- Joint 4: Wrist roll (X-axis) -->
  <!-- Origin: end of link3 (x=0.25 from link3) -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin rpy="0 0 0" xyz="0.25 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="30.0" lower="-3.14159" upper="3.14159" velocity="3.0"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>
  <!-- ═══════════════════════════════════════════════════════════════════
       LINK 5 — Wrist 2 (pitch)
       Dimensions: cylinder h=0.08 m, r=0.030 m
       Mass: 0.3 kg
       Joint5 is revolute around Y-axis (pitch)
       ═══════════════════════════════════════════════════════════════════ -->
  <link name="link5">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.04"/>
