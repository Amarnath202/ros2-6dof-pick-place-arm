  </link>
  <!-- Fixed joint: link6 -> gripper_base_link -->
  <joint name="joint6_to_gripper" type="fixed">
    <parent link="link6"/>
    <child link="gripper_base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.06"/>
  </joint>
  <!-- ═══════════════════════════════════════════════════════════════════
       LEFT FINGER LINK
       Prismatic: slides along Y-axis (outward = open)
       Dimensions: box 0.015 × 0.07 × 0.015 m
